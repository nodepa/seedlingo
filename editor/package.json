{
  "name": "apiary",
  "version": "1.0.0",
  "description": "Content editor for Seedlingo",
  "homepage": "https://seedlingo.com",
  "bugs": "https://github.com/nodepa/seedlingo/issues",
  "repository": "https://github.com/nodepa/seedlingo",
  "private": true,
  "license": "MIT",
  "keywords": [
    "seedlingo",
    "literacy",
    "digital-learning",
    "education",
    "edtech",
    "reading",
    "vuejs",
    "typescript",
    "editor"
  ],
  "type": "module",
  "main": "src/main.js",
  "lint-staged": {
    "*.{ts,mts,cts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yaml,yml}": "prettier --write"
  },
  "scripts": {
    "build": "npm run lint && npm run typecheck && nuxi build",
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "lint": "eslint",
    "login": "aws sso login",
    "preview": "nuxi preview",
    "sandbox": "ampx sandbox",
    "setup": "allow-scripts && nuxi prepare",
    "start": "nuxi build && nuxi preview",
    "test": "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:dev": "E2E_DEV=1 playwright test",
    "test:e2e:dev:open": "E2E_DEV=1 playwright test --ui",
    "test:e2e:dev:unserved": "E2E_DEV=1 E2E_NO_SERVER=1 playwright test",
    "test:e2e:open": "playwright test --ui",
    "test:e2e:unserved": "E2E_NO_SERVER=1 playwright test",
    "test:unit": "vitest run --reporter dot",
    "test:unit:ci": "NO_COLOR=1 vitest run --reporter agent",
    "test:unit:coverage": "vitest run --reporter dot --coverage",
    "test:unit:verbose": "vitest --reporter verbose",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "@aws-amplify/ui-vue": "^4.4.2",
    "@ionic/vue": "^8.8.3",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.6.1",
    "aws-amplify": "^6.16.3",
    "ionicons": "^8.0.13",
    "nuxt": "^4.4.2",
    "unstorage": "^1.17.5",
    "valibot": "^1.3.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@iconify-json/mdi": "^1.2.3",
    "@lavamoat/allow-scripts": "^4.0.0",
    "@lavamoat/preinstall-always-fail": "^3.0.0",
    "@nuxt/test-utils": "^4.0.0",
    "@plausible-analytics/tracker": "^0.4.4",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "aws-cdk": "^2.1117.0",
    "aws-cdk-lib": "^2.248.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@aws-amplify/backend": {
      "lodash": ">=4.17.23"
    },
    "@aws-amplify/ui-vue": {
      "@vueuse/core": ">=10.0.0"
    },
    "@nuxt/test-utils": {
      "h3": ">=2.0.1-rc.15",
      "h3-next": "npm:h3@>=2.0.1-rc.15",
      "lodash": ">=4.17.23"
    },
    "@nuxt/ui": {
      "nuxt": ">=4.4.2",
      "vue-router": ">=5.0.3"
    },
    "@rollup/plugin-terser": {
      "serialize-javascript": ">=7.0.3"
    },
    "@smithy/config-resolver": ">=4.4.0",
    "@xmldom/xmldom": "^0.9.9",
    "fast-xml-parser": ">=5.5.6",
    "glob": "^13.0.6",
    "immutable": ">=3.8.3",
    "lodash": ">=4.17.23",
    "minimatch": ">=10.2.3",
    "serialize-javascript": ">=7.0.3",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.14",
    "vite-plugin-pwa": {
      "vite": ">=8.0.0"
    }
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.12.1"
  },
  "lavamoat": {
    "allowScripts": {
      "$root$": false,
      "@aws-amplify/backend-cli>@aws-amplify/backend-deployer>tsx>esbuild": true,
      "@aws-amplify/backend-cli>@aws-amplify/model-generator>@aws-amplify/graphql-types-generator>babel-types>babel-runtime>core-js": false,
      "@aws-amplify/backend-cli>@aws-amplify/model-generator>@aws-amplify/graphql-types-generator>core-js": false,
      "@lavamoat/preinstall-always-fail": false,
      "@playwright/test": true,
      "@nuxt/image>ipx>sharp": true,
      "@nuxt/ui>reka-ui>@floating-ui/vue>vue-demi": true,
      "esbuild": true,
      "nuxt>@parcel/watcher": true,
      "@aws-amplify/backend-cli>@aws-amplify/sandbox>@aws-amplify/backend-deployer>tsx>esbuild": false,
      "@nuxt/ui>@nuxt/fonts>fontless>esbuild": false,
      "@nuxt/ui>vaul-vue>@vueuse/core>@vueuse/shared>vue-demi": false,
      "@nuxt/ui>vaul-vue>@vueuse/core>vue-demi": false,
      "nuxt>@nuxt/devtools>vite>esbuild": false,
      "nuxt>@nuxt/nitro-server>nitropack>esbuild": false,
      "nuxt>@nuxt/vite-builder>vite-node>vite>esbuild": false,
      "nuxt>@nuxt/vite-builder>vite>esbuild": false,
      "tsx>esbuild": false
    }
  }
}
