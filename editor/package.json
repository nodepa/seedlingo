{
  "name": "apiary",
  "version": "1.0.0",
  "description": "Content editor for Seedlingo",
  "homepage": "https://seedlingo.com",
  "bugs": "https://github.com/nodepa/seedlingo/issues",
  "repository": "https://github.com/nodepa/seedlingo",
  "private": true,
  "license": "MIT",
  "keywords": [
    "seedlingo",
    "literacy",
    "digital-learning",
    "education",
    "edtech",
    "reading",
    "vuejs",
    "typescript",
    "editor"
  ],
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "lint": "eslint .",
    "lint:tsc": "nuxi typecheck",
    "login": "aws sso login",
    "postinstall": "nuxi prepare",
    "preview": "nuxi preview",
    "sandbox": "ampx sandbox",
    "test": "npm run lint:tsc && npm run test:unit && npm run test:e2e",
    "test:e2e": "start-server-and-test preview :3000 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test dev :3000 'cypress run --e2e --config baseUrl=http://localhost:3000'",
    "test:e2e:dev:open": "start-server-and-test dev :3000 'cypress open --e2e -b electron --config baseUrl=http://localhost:3000'",
    "test:unit": "vitest run --reporter dot",
    "test:unit:coverage": "vitest run --reporter dot --coverage",
    "test:unit:dev": "vitest --reporter dot",
    "test:unit:verbose": "vitest --reporter verbose"
  },
  "dependencies": {
    "@aws-amplify/ui-vue": "^4.4.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.1",
    "aws-amplify": "^6.16.3",
    "nuxt": "^4.4.2",
    "valibot": "^1.2.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.21.1",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/test-utils": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "aws-cdk": "^2.1111.0",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.5.1",
    "cypress": "^15.12.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.4",
    "start-server-and-test": "^2.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@nuxt/ui": {
      "nuxt": ">=4.4.2"
    },
    "fast-xml-parser": ">=4.5.4",
    "immutable": ">=3.8.3",
    "lodash": ">=4.17.23",
    "minimatch": ">=10.2.3",
    "serialize-javascript": ">=7.0.3",
    "@smithy/config-resolver": ">=4.4.0"
  },
  "volta": {
    "node": "24.13.1",
    "npm": "11.10.1"
  }
}
