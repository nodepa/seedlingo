{
  "name": "apiary",
  "version": "1.0.0",
  "description": "Content editor for Seedlingo",
  "homepage": "https://seedlingo.com",
  "bugs": "https://github.com/nodepa/seedlingo/issues",
  "repository": "https://github.com/nodepa/seedlingo",
  "private": true,
  "license": "MIT",
  "keywords": [
    "seedlingo",
    "literacy",
    "digital-learning",
    "education",
    "edtech",
    "reading",
    "vuejs",
    "typescript",
    "editor"
  ],
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "lint": "eslint",
    "lint:tsc": "nuxi typecheck",
    "login": "aws sso login",
    "postinstall": "nuxi prepare",
    "preview": "nuxi preview",
    "sandbox": "ampx sandbox",
    "setup": "allow-scripts && nuxi prepare",
    "start": "nuxi build && nuxi preview",
    "test": "npm run lint && npm run lint:tsc && npm run test:unit && npm run test:e2e",
    "test:e2e": "start-server-and-test start :3000 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test dev :3000 'cypress run --e2e --config baseUrl=http://localhost:3000'",
    "test:e2e:dev:open": "start-server-and-test dev :3000 'cypress open --e2e -b electron --config baseUrl=http://localhost:3000'",
    "test:unit": "vitest run --reporter dot",
    "test:unit:coverage": "vitest run --reporter dot --coverage",
    "test:unit:dev": "vitest --reporter dot",
    "test:unit:verbose": "vitest --reporter verbose"
  },
  "dependencies": {
    "@aws-amplify/ui-vue": "^4.4.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.1",
    "aws-amplify": "^6.16.3",
    "nuxt": "^4.4.2",
    "valibot": "^1.3.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.21.1",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@iconify-json/mdi": "^1.2.3",
    "@lavamoat/allow-scripts": "^3.4.3",
    "@lavamoat/preinstall-always-fail": "^2.1.1",
    "@nuxt/test-utils": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "aws-cdk": "^2.1112.0",
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.5.1",
    "cypress": "^15.12.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.4",
    "start-server-and-test": "^2.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@aws-amplify/backend": {
      "lodash": ">=4.17.23"
    },
    "@aws-amplify/ui-vue": {
      "@vueuse/core": ">=10.0.0"
    },
    "@nuxt/test-utils": {
      "h3": ">=2.0.1-rc.15",
      "h3-next": "npm:h3@>=2.0.1-rc.15",
      "lodash": ">=4.17.23"
    },
    "@nuxt/ui": {
      "nuxt": ">=4.4.2",
      "vue-router": ">=5.0.3"
    },
    "@rollup/plugin-terser": {
      "serialize-javascript": ">=7.0.3"
    },
    "@smithy/config-resolver": ">=4.4.0",
    "fast-xml-parser": ">=5.5.6",
    "immutable": ">=3.8.3",
    "lodash": ">=4.17.23",
    "minimatch": ">=10.2.3",
    "mocha": {
      "diff": ">=8.0.2",
      "serialize-javascript": ">=7.0.3"
    },
    "serialize-javascript": ">=7.0.3",
    "vite-plugin-pwa": {
      "vite": ">=8.0.0"
    }
  },
  "volta": {
    "node": "24.13.1",
    "npm": "11.10.1"
  },
  "lavamoat": {
    "allowScripts": {
      "$root$": false,
      "@aws-amplify/backend-cli>@aws-amplify/backend-deployer>tsx>esbuild": true,
      "@aws-amplify/backend-cli>@aws-amplify/model-generator>@aws-amplify/graphql-types-generator>babel-types>babel-runtime>core-js": false,
      "@aws-amplify/backend-cli>@aws-amplify/model-generator>@aws-amplify/graphql-types-generator>core-js": false,
      "@lavamoat/preinstall-always-fail": false,
      "@nuxt/image>ipx>sharp": true,
      "@nuxt/ui>reka-ui>@floating-ui/vue>vue-demi": true,
      "cypress": true,
      "esbuild": true,
      "nuxt>@parcel/watcher": true
    }
  }
}
